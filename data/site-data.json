  "curriculum": [
    {
      "sessionNo": 1,
      "title": "市場と勝ち筋を決める（価値設計）",
      "bullets": [
        "稼げるテーマは「好き」ではなく「需要×支払い意欲×供給過多の回避」で決める",
        "「誰の何をいくらで解決するか」を1行で言えるまで詰める",
        "AI活用：ペルソナ深掘り / 競合リサーチ自動化 / 市場ニーズの言語化"
      ],
      "deliverable": "マネタイズ設計書"
    },
    {
      "sessionNo": 2,
      "title": "売れる商品を設計する（商品設計）",
      "bullets": [
        "商品を「内容」から作らない。「オファー（約束＋提供方法＋特典＋価格）」から作る",
        "初回は必ず「売りやすい型」に寄せる（note/Brain/テンプレ/添削/壁打ち等）",
        "AI活用：商品コンセプト案の大量生成 / 目次構成の自動作成 / 特典アイデア出し"
      ],
      "deliverable": "商品タイトル案 / 目次 / 販売ページ骨子"
    },
    {
      "sessionNo": 3,
      "title": "投稿を「売上目的」で再設計する（発信設計）",
      "bullets": [
        "投稿を3つの役割で使い分け",
        "**集客投稿**: 興味を引いてフォロワーを増やす",
        "**教育投稿**: 「これ必要だな」と気づかせる",
        "**販売投稿**: 「今すぐ買おう」と行動させる",
        "AI活用：バズ投稿の型分析 / 切り口の大量生成 / 投稿30本の一括作成"
      ],
      "deliverable": "役割付き投稿30本 / 固定投稿"
    },
    {
      "sessionNo": 4,
      "title": "売れる販売ページを完成させる（販売設計）",
      "bullets": [
        "「売れない」の原因は9割が販売ページ",
        "noteとBrain両方の販売ページを完成させる",
        "AI活用：セールスコピー生成 / 販売ページ全文の下書き作成 / ヘッドライン案の量産"
      ],
      "deliverable": "note / Brain 有料部分完成"
    },
    {
      "sessionNo": 5,
      "title": "AI×SNS運用を仕組み化する",
      "bullets": [
        "投稿作成・分析・改善のすべてをAIで回せる状態に仕上げる",
        "属人性を残しつつ、作業時間を最小化（1日30分以下）",
        "AI活用：投稿の自動生成ワークフロー構築 / エンゲージ分析の自動化"
      ],
      "deliverable": "AI×SNS運用マニュアル / 自動化フロー"
    },
    {
      "sessionNo": 6,
      "title": "ローンチ＆高単価商品設計",
      "bullets": [
        "販売データの読み方と改善方法",
        "高単価商品（講座・コンサル等）の設計方法",
        "低単価noteで安定収益 + 高単価商品で跳ね上げる「二段構えの収益構造」",
        "AI活用：販売データの分析 / 改善ポイントの抽出 / 高額商品のコンセプト設計"
      ],
      "deliverable": "販売結果レポート / 高単価商品の企画書"
    }
  ],
